---
import '../styles/global.css';

import Header from '../components/Header.astro';
import ComicCard from '../components/ComicCard.astro';
import CartDrawer from '../components/CartDrawer.astro';
import Footer from '../components/Footer.astro';

const API_URL = import.meta.env.PUBLIC_API_URL || 'http://127.0.0.1:8000/api';

let comics = [];
try {
    const respuesta = await fetch(`${API_URL}/comics`);
    if (respuesta.ok) {
        comics = await respuesta.json();
    }
} catch (error) {
    console.error("Error al obtener los cómics en la página de catálogo:", error);
}

// Defined categories for the sidebar
const categorias = ["Marvel", "DC", "Manga", "Independiente"];
---
<html lang="es">
<head>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Catálogo - Comiquería Aguilar</title>

    <meta property="og:type" content="website" />
    <meta property="og:title" content="Catálogo - Comiquería Aguilar" />
    <meta property="og:description" content="Explora nuestro extenso catálogo de cómics y mangas." />
    <meta property="og:url" content="https://comiqueriaaguilar.vercel.app/catalogo" />

    <script async src="https://www.googletagmanager.com/gtag/js?id=G-6DMZEKJL62"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-6DMZEKJL62');
    </script>

    <script is:inline src="https://www.paypal.com/sdk/js?client-id=test&currency=USD"></script>

</head>

<body class="bg-gray-50 text-gray-900 font-sans min-h-screen selection:bg-red-200 selection:text-black flex flex-col">
    
    <Header />

    <div class="max-w-7xl mx-auto w-full pt-32 pb-24 px-6 flex flex-col md:flex-row gap-10 grow">
        <!-- Sidebar Menu -->
        <aside class="w-full md:w-64 shrink-0">
            <div class="bg-white rounded-2xl p-6 shadow-xl border border-gray-100 sticky top-28">
                <h3 class="text-xl font-black text-gray-900 mb-6 border-b pb-4">Filtrar por</h3>
                
                <!-- Buscador Integrado -->
                <div class="mb-6">
                    <input 
                        type="text" 
                        id="buscador-catalogo"
                        placeholder="Buscar título..." 
                        class="w-full bg-gray-50 border border-gray-200 focus:bg-white focus:border-red-400 rounded-xl py-2 px-4 text-sm outline-none transition-all shadow-inner"
                    />
                </div>

                <!-- FORMATOS -->
                <div class="mb-6">
                    <h4 class="text-sm font-bold text-gray-400 uppercase tracking-wider mb-3">2. Formatos</h4>
                    <div class="space-y-3 pl-1" id="formatos-filter">
                        <label class="flex items-center gap-3 cursor-pointer group">
                            <input type="radio" name="formato" value="todos" class="peer sr-only" checked>
                            <div class="w-5 h-5 rounded-full border-2 border-gray-300 peer-checked:border-red-500 peer-checked:border-[6px] transition-all group-hover:border-red-400"></div>
                            <span class="text-gray-600 text-sm peer-checked:font-bold peer-checked:text-gray-900 transition-colors">Todos los formatos</span>
                        </label>
                        <label class="flex items-center gap-3 cursor-pointer group">
                            <input type="radio" name="formato" value="comics" class="peer sr-only">
                            <div class="w-5 h-5 rounded-full border-2 border-gray-300 peer-checked:border-red-500 peer-checked:border-[6px] transition-all group-hover:border-red-400"></div>
                            <span class="text-gray-600 text-sm peer-checked:font-bold peer-checked:text-gray-900 transition-colors">Cómics</span>
                        </label>
                        <label class="flex items-center gap-3 cursor-pointer group">
                            <input type="radio" name="formato" value="mangas" class="peer sr-only">
                            <div class="w-5 h-5 rounded-full border-2 border-gray-300 peer-checked:border-red-500 peer-checked:border-[6px] transition-all group-hover:border-red-400"></div>
                            <span class="text-gray-600 text-sm peer-checked:font-bold peer-checked:text-gray-900 transition-colors">Mangas</span>
                        </label>
                        <label class="flex items-center gap-3 cursor-pointer group">
                            <input type="radio" name="formato" value="novelas" class="peer sr-only">
                            <div class="w-5 h-5 rounded-full border-2 border-gray-300 peer-checked:border-red-500 peer-checked:border-[6px] transition-all group-hover:border-red-400"></div>
                            <span class="text-gray-600 text-sm peer-checked:font-bold peer-checked:text-gray-900 transition-colors">Novelas Visuales</span>
                        </label>
                    </div>
                </div>

                <!-- EDITORIALES -->
                <details class="mb-6 group" open>
                    <summary class="text-sm font-bold text-gray-400 uppercase tracking-wider mb-3 cursor-pointer select-none flex items-center justify-between">
                        3. Editoriales
                        <svg class="w-4 h-4 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
                    </summary>
                    <div class="space-y-3 pl-1 mt-3">
                        {['Marvel Comics', 'DC Comics', 'Image Comics', 'Panini Manga', 'Norma Editorial', 'Ivrea', 'Independiente'].map(ed => (
                            <label class="flex items-center gap-3 cursor-pointer group">
                                <input type="checkbox" name="editorial" value={ed} class="peer sr-only">
                                <div class="w-5 h-5 rounded flex items-center justify-center border-2 border-gray-300 peer-checked:bg-red-500 peer-checked:border-red-500 transition-all group-hover:border-red-400">
                                    <svg class="w-3 h-3 text-white opacity-0 peer-checked:opacity-100 transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>
                                </div>
                                <span class="text-gray-600 text-sm peer-checked:font-bold peer-checked:text-gray-900 transition-colors">{ed}</span>
                            </label>
                        ))}
                    </div>
                </details>

                <!-- GÉNEROS -->
                <details class="mb-6 group" open>
                    <summary class="text-sm font-bold text-gray-400 uppercase tracking-wider mb-3 cursor-pointer select-none flex items-center justify-between">
                        4. Géneros
                        <svg class="w-4 h-4 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
                    </summary>
                    <div class="space-y-3 pl-1 mt-3">
                        {['Acción', 'Aventura', 'Ciencia Ficción', 'Fantasía', 'Terror / Psicológico', 'Romance', 'Recuentos de la vida (Slice of Life)', 'Misterio / Suspense', 'Isekai'].map(gen => (
                            <label class="flex items-center gap-3 cursor-pointer group">
                                <input type="checkbox" name="genero" value={gen} class="peer sr-only">
                                <div class="w-5 h-5 rounded flex items-center justify-center border-2 border-gray-300 peer-checked:bg-red-500 peer-checked:border-red-500 transition-all group-hover:border-red-400">
                                    <svg class="w-3 h-3 text-white opacity-0 peer-checked:opacity-100 transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>
                                </div>
                                <span class="text-gray-600 text-sm peer-checked:font-bold peer-checked:text-gray-900 transition-colors">{gen}</span>
                            </label>
                        ))}
                    </div>
                </details>

                <!-- DEMOGRAFÍA -->
                <div id="demografia-section" class="hidden mb-6">
                    <h4 class="text-sm font-bold text-gray-400 uppercase tracking-wider mb-3">5. Demografía</h4>
                    <div class="space-y-3 pl-1">
                        {['Shounen', 'Seinen', 'Shoujo', 'Josei'].map(demo => (
                            <label class="flex items-center gap-3 cursor-pointer group">
                                <input type="checkbox" name="demografia" value={demo} class="peer sr-only">
                                <div class="w-5 h-5 rounded flex items-center justify-center border-2 border-gray-300 peer-checked:bg-red-500 peer-checked:border-red-500 transition-all group-hover:border-red-400">
                                    <svg class="w-3 h-3 text-white opacity-0 peer-checked:opacity-100 transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>
                                </div>
                                <span class="text-gray-600 text-sm peer-checked:font-bold peer-checked:text-gray-900 transition-colors">{demo}</span>
                            </label>
                        ))}
                    </div>
                </div>
            </div>
        </aside>

        <!-- Catalog Grid -->
        <main class="grow w-full">
            <div class="flex items-center justify-between mb-8">
                <h2 class="text-4xl font-black text-gray-900 border-l-4 border-red-500 pl-4" id="catalog-title">Todos los Cómics</h2>
                <span id="results-count" class="text-gray-500 font-bold">{comics.length} resultados</span>
            </div>
            
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8" id="comics-grid">
                {comics.map((comic) => (
                    <ComicCard comic={comic} />
                ))}
                
                <div id="no-results" class="hidden col-span-full text-center py-16 bg-white rounded-2xl shadow-sm border border-gray-100">
                    <p class="text-4xl mb-4">😢</p>
                    <p class="text-xl text-gray-500 font-bold">No encontramos ningún cómic con esos filtros.</p>
                </div>
            </div>
        </main>
    </div>

    <CartDrawer />

    <Footer />

    <!-- Botón de Carrito Mejorado -->
    <button id="btn-abrir-carrito" class="fixed bottom-6 right-6 bg-red-600 hover:bg-red-700 text-white p-4 rounded-full shadow-[0_10px_25px_-5px_rgba(220,38,38,0.5)] hover:shadow-[0_15px_35px_-5px_rgba(220,38,38,0.6)] hover:-translate-y-1 transition-all z-50 flex items-center justify-center group duration-300">
        <span class="absolute right-16 bg-white text-gray-900 text-sm font-bold px-3 py-1.5 rounded-lg opacity-0 group-hover:opacity-100 group-hover:-translate-x-2 transition-all duration-300 whitespace-nowrap shadow-xl pointer-events-none border border-gray-100">
            Ver Carrito
        </span>
        <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path></svg>
        <span id="cart-count" class="absolute -top-2 -right-2 bg-red-500 text-white text-xs font-black px-2 py-1 rounded-full border-2 border-white shadow-sm min-w-[24px]">0</span>
    </button>

    <!-- Contenedor de Botones Sociales y Soporte -->
    <div class="fixed bottom-6 left-6 z-50 flex flex-col gap-4">
        <!-- Custom Tawk.to Button -->
        <button onclick="Tawk_API.maximize()" class="bg-blue-500 hover:bg-blue-600 text-white p-4 rounded-full shadow-[0_10px_25px_-5px_rgba(59,130,246,0.5)] hover:shadow-[0_15px_35px_-5px_rgba(59,130,246,0.6)] hover:-translate-y-1 transition-all flex items-center justify-center group relative duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
        </button>
        <!-- WhatsApp Button Mejorado -->
        <a href="https://wa.me/59177124861" target="_blank" rel="noopener noreferrer" class="bg-[#25D366] hover:bg-[#20b858] text-white p-4 rounded-full shadow-[0_10px_25px_-5px_rgba(37,211,102,0.5)] hover:shadow-[0_15px_35px_-5px_rgba(37,211,102,0.6)] hover:-translate-y-1 transition-all flex items-center justify-center group relative duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="currentColor" stroke="none"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
        </a>
    </div>

    <!-- Scripts unificados -->
    <script is:inline>
        document.addEventListener('DOMContentLoaded', () => {
            
            let carrito = JSON.parse(localStorage.getItem('carritoStore')) || [];

            window.agregarAlCarrito = function(id, titulo, precio, imagen) {
                const itemExistente = carrito.find(item => item.id === id);
                if(itemExistente) {
                    itemExistente.cantidad += 1;
                } else {
                    carrito.push({ id, titulo, precio, imagen, cantidad: 1 });
                }
                guardarCarrito();
                abrirCarrito();
            };

            window.eliminarDelCarrito = function(id) {
                carrito = carrito.filter(item => item.id !== id);
                guardarCarrito();
            };

            function guardarCarrito() {
                localStorage.setItem('carritoStore', JSON.stringify(carrito));
                actualizarUI();
            }

            function actualizarUI() {
                const totalItems = carrito.reduce((acc, item) => acc + item.cantidad, 0);
                const cartCountEl = document.getElementById('cart-count');
                if(cartCountEl) cartCountEl.innerText = totalItems;

                const contenedor = document.getElementById('cart-items');
                if(!contenedor) return;
                
                contenedor.innerHTML = '';
                let totalCosto = 0;

                if(carrito.length === 0) {
                    contenedor.innerHTML = '<div class="text-center text-gray-400 mt-10"><p class="text-4xl mb-2">🛒</p><p>Tu carrito está vacío.</p></div>';
                } else {
                    carrito.forEach(item => {
                        totalCosto += (item.precio * item.cantidad);
                        contenedor.innerHTML += `
                            <div class="flex items-center gap-4 bg-white p-3 rounded-xl border border-gray-100 shadow-sm">
                                <img src="${item.imagen}" class="w-16 h-16 object-cover rounded-lg" />
                                <div class="flex-grow">
                                    <h4 class="font-bold text-sm text-gray-900 leading-tight">${item.titulo}</h4>
                                    <p class="text-red-600 font-bold text-sm">Bs. ${item.precio} <span class="text-gray-400 font-normal">x ${item.cantidad}</span></p>
                                </div>
                                <button onclick="eliminarDelCarrito('${item.id}')" class="text-red-400 hover:text-red-600 p-2 font-black transition-colors">✖</button>
                            </div>
                        `;
                    });
                }

                const totalEl = document.getElementById('cart-total');
                if(totalEl) totalEl.innerText = `Bs. ${totalCosto.toFixed(2)}`;
            }

            const modal = document.getElementById('cart-modal');
            const drawer = document.getElementById('cart-drawer');

            function abrirCarrito() {
                if(!modal || !drawer) return;
                modal.classList.remove('hidden');
                setTimeout(() => drawer.classList.remove('translate-x-full'), 10);
            }

            function cerrarCarrito() {
                if(!modal || !drawer) return;
                drawer.classList.add('translate-x-full');
                setTimeout(() => modal.classList.add('hidden'), 300);
            }

            const btnAbrir = document.getElementById('btn-abrir-carrito');
            const btnCerrar = document.getElementById('btn-cerrar-carrito');
            if(btnAbrir) btnAbrir.addEventListener('click', abrirCarrito);
            if(btnCerrar) btnCerrar.addEventListener('click', cerrarCarrito);
            document.getElementById('btn-seguir-comprando')?.addEventListener('click', cerrarCarrito);
            
            actualizarUI();

            // REFERENCIAS DOM PARA FILTROS
            const formatosRadios = document.querySelectorAll('input[name="formato"]');
            const editorialesCb = document.querySelectorAll('input[name="editorial"]');
            const generosCb = document.querySelectorAll('input[name="genero"]');
            const demografiaCb = document.querySelectorAll('input[name="demografia"]');
            const demografiaSection = document.getElementById('demografia-section');

            const searchInput = document.getElementById('buscador-catalogo');
            const globalSearchInput = document.getElementById('buscador');
            const comicCards = document.querySelectorAll('.comic-card');
            const noResults = document.getElementById('no-results');
            const catalogTitle = document.getElementById('catalog-title');
            const resultsCount = document.getElementById('results-count');

            let currentSearch = '';

            // VISIBILIDAD DE DEMOGRAFIA
            formatosRadios.forEach(radio => {
                radio.addEventListener('change', (e) => {
                    if (e.target.value === 'mangas') {
                        demografiaSection.classList.remove('hidden');
                    } else {
                        demografiaSection.classList.add('hidden');
                        // Limpiar selección de demografía al ocultar
                        demografiaCb.forEach(cb => cb.checked = false);
                    }
                    applyFilters();
                });
            });

            // LISTENERS PARA CHECKBOXES
            [...editorialesCb, ...generosCb, ...demografiaCb].forEach(cb => {
                cb.addEventListener('change', applyFilters);
            });

            // LISTENERS PARA BUSCADOR
            if (searchInput) {
                searchInput.addEventListener('input', (e) => {
                    currentSearch = e.target.value.toLowerCase();
                    applyFilters();
                });
            }
            if (globalSearchInput) {
                globalSearchInput.addEventListener('input', (e) => {
                    currentSearch = e.target.value.toLowerCase();
                    applyFilters();
                });
            }

            function applyFilters() {
                // Obtener formato seleccionado
                const formatoSeleccionado = document.querySelector('input[name="formato"]:checked')?.value || 'todos';
                
                // Obtener checkboxes seleccionados
                const editorialesSeleccionadas = Array.from(editorialesCb).filter(cb => cb.checked).map(cb => cb.value);
                const generosSeleccionados = Array.from(generosCb).filter(cb => cb.checked).map(cb => cb.value);
                const demografiasSeleccionadas = Array.from(demografiaCb).filter(cb => cb.checked).map(cb => cb.value);

                let visibleCount = 0;

                comicCards.forEach(card => {
                    const title = card.getAttribute('data-titulo').toLowerCase();
                    const cardFormato = card.getAttribute('data-formato');
                    
                    // Arrays en data attributes pueden venir como '[]' o nulos
                    let cardEditoriales = [];
                    let cardGeneros = [];
                    let cardDemografias = [];
                    
                    try { cardEditoriales = JSON.parse(card.getAttribute('data-editorial') || '[]'); } catch(e) {}
                    try { cardGeneros = JSON.parse(card.getAttribute('data-genero') || '[]'); } catch(e) {}
                    try { cardDemografias = JSON.parse(card.getAttribute('data-demografia') || '[]'); } catch(e) {}

                    const matchesSearch = title.includes(currentSearch);
                    const matchesFormato = (formatoSeleccionado === 'todos' || cardFormato === formatoSeleccionado);
                    
                    // Si el usuario seleccionó al menos un filtro de este tipo, el cómic debe tener al menos uno coincidente.
                    // Si el usuario no seleccionó ninguno, se considera que coincide.
                    const matchesEditorial = editorialesSeleccionadas.length === 0 || editorialesSeleccionadas.some(ed => cardEditoriales.includes(ed));
                    const matchesGenero = generosSeleccionados.length === 0 || generosSeleccionados.some(gen => cardGeneros.includes(gen));
                    // Para demografia, ignorar si no es manga
                    const matchesDemografia = demografiasSeleccionadas.length === 0 || (formatoSeleccionado === 'mangas' && demografiasSeleccionadas.some(demo => cardDemografias.includes(demo)));

                    if (matchesSearch && matchesFormato && matchesEditorial && matchesGenero && matchesDemografia) {
                        card.style.display = 'flex';
                        visibleCount++;
                    } else {
                        card.style.display = 'none';
                    }
                });

                if (visibleCount === 0) {
                    noResults.classList.remove('hidden');
                } else {
                    noResults.classList.add('hidden');
                }
                
                resultsCount.innerText = `${visibleCount} resultado${visibleCount !== 1 ? 's' : ''}`;
                
                // Actualizar título de la sección
                const formatoLabelMap = { 'todos': 'Todos los Cómics', 'comics': 'Cómics', 'mangas': 'Mangas', 'novelas': 'Novelas Visuales' };
                catalogTitle.innerText = formatoLabelMap[formatoSeleccionado] || 'Cómics';
            }
        });
    </script>

    <script is:inline type="text/javascript">
        var Tawk_API=Tawk_API||{}, Tawk_LoadStart=new Date();
        Tawk_API.onLoad = function(){ Tawk_API.hideWidget(); };
        Tawk_API.onChatMaximized = function(){ Tawk_API.showWidget(); };
        Tawk_API.onChatMinimized = function(){ Tawk_API.hideWidget(); };
        (function(){
        var s1=document.createElement("script"),s0=document.getElementsByTagName("script")[0];
        s1.async=true;
        s1.src='https://embed.tawk.to/6a300cd3aca9b41d46d770a1/1jr5r46v4';
        s1.charset='UTF-8';
        s1.setAttribute('crossorigin','*');
        s0.parentNode.insertBefore(s1,s0);
        })();
    </script>
</body>
</html>
