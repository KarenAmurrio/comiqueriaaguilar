---
import '../styles/global.css';

import Header from '../components/Header.astro';
import Carousel from '../components/Carousel.astro';
import ComicCard from '../components/ComicCard.astro';
import CartDrawer from '../components/CartDrawer.astro';
import Footer from '../components/Footer.astro';

const API_URL = import.meta.env.PUBLIC_API_URL || 'http://127.0.0.1:8000/api';

let comics = [];
try {
    const respuesta = await fetch(`${API_URL}/comics`);
    if (respuesta.ok) {
        comics = await respuesta.json();
    }
} catch (error) {
    console.error("Error al obtener los cómics en la página de inicio:", error);
}
