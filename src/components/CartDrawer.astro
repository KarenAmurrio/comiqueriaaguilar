---
// src/components/CartDrawer.astro
---
<div id="cart-modal" class="fixed inset-0 bg-black/50 z-50 hidden flex justify-end transition-opacity">
    <div id="cart-drawer" class="bg-white w-full max-w-md h-full shadow-2xl flex flex-col transform translate-x-full transition-transform duration-300">
        <div class="p-6 border-b border-gray-200 flex justify-between items-center bg-gray-50">
            <h2 class="text-2xl font-black text-gray-900">Tu Carrito</h2>
            <button id="btn-cerrar-carrito" class="text-gray-400 hover:text-red-500 text-2xl font-bold transition-colors">&times;</button>
        </div>
        <div id="cart-items" class="p-6 flex-grow overflow-y-auto flex flex-col gap-4 bg-white">
            </div>
        <div class="p-6 border-t border-gray-200 bg-gray-50">
            <div class="flex justify-between items-center mb-6">
                <span class="font-bold text-gray-600 text-lg">Total estimado:</span>
                <span id="cart-total" class="font-black text-3xl text-red-600">Bs. 0.00</span>
            </div>
            
            <div class="flex flex-col gap-3 mt-4">
                <a href="/checkout" class="bg-red-600 hover:bg-red-500 text-white text-center font-black py-3 px-4 rounded-xl shadow-lg transition-all hover:scale-105">
                    Realizar Compra
                </a>
                <button id="btn-seguir-comprando" class="text-gray-500 text-sm font-bold hover:text-red-600 transition-colors py-2">
                    Seguir viendo productos
                </button>
            </div>
        </div>
    </div>
</div>