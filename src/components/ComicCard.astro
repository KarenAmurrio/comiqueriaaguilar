---
// src/components/ComicCard.astro
const { comic } = Astro.props;

// Convierte propiedades con seguridad a string o JSON
const formato = comic.formato || 'todos';
const editorialStr = comic.editorial ? JSON.stringify(comic.editorial) : '[]';
const generoStr = comic.genero ? JSON.stringify(comic.genero) : '[]';
const demografiaStr = comic.demografia ? JSON.stringify(comic.demografia) : '[]';
---
<div class="comic-card group bg-white rounded-2xl overflow-hidden shadow-md border border-gray-200 hover:border-red-300 hover:shadow-2xl transition-all duration-300 flex flex-col relative hover:-translate-y-2" 
    data-titulo={comic.titulo} 
    data-categoria={comic.categoria || ''}
    data-formato={formato}
    data-editorial={editorialStr}
    data-genero={generoStr}
    data-demografia={demografiaStr}
>
    {comic.stock < 3 && comic.stock > 0 && (
        <span class="absolute top-4 right-4 bg-yellow-400 text-yellow-900 text-xs font-black px-3 py-1 rounded-full z-10 shadow-sm">ÚLTIMAS {comic.stock}</span>
    )}
    {comic.stock == 0 && (
        <span class="absolute top-4 right-4 bg-red-100 text-red-600 text-xs font-black px-3 py-1 rounded-full z-10 shadow-sm">AGOTADO</span>
    )}

    <a href={`/comic/${comic.id}`} class="h-80 overflow-hidden relative bg-gray-100 block">
        <img src={comic.imagen_url} alt={comic.titulo} class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-500" />
    </a>
    
    <div class="p-6 flex flex-col grow relative z-20">
        <a href={`/comic/${comic.id}`} class="hover:text-red-600 transition-colors">
            <h3 class="text-xl font-black text-gray-900 mb-2 leading-tight">{comic.titulo}</h3>
        </a>
        <p class="text-sm text-gray-500 line-clamp-2">{comic.descripcion}</p>
        
        <div class="mt-auto pt-6 flex items-center justify-between">
            <p class="text-2xl font-black text-gray-900">Bs. {comic.precio}</p>
            
            <button 
                onclick={`agregarAlCarrito('${comic.id}', '${comic.titulo.replace(/'/g, "\\'")}', ${comic.precio}, '${comic.imagen_url}')`}
                disabled={comic.stock == 0}
                class="bg-red-600 hover:bg-red-500 disabled:bg-gray-400 text-white font-bold py-2 px-4 rounded-xl shadow-md transition-colors"
            >
                {comic.stock == 0 ? 'Agotado' : '+ Añadir'}
            </button>
        </div>
        
        <div id={`paypal-button-${comic.id}`} class="mt-4 hidden"></div>
        <script is:inline define:vars={{ comicId: comic.id, comicPrecio: comic.precio, comicTitulo: comic.titulo }}>
            // Este bloque se mantiene listo por compatibilidad individual o depuración externa
        </script>
    </div>
</div>