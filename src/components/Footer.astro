---
// src/components/Footer.astro
---
<footer class="relative border-t border-gray-200 bg-white w-full mt-auto overflow-hidden">
    <!-- Subtle gradient accent at the top -->
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-red-500 to-transparent"></div>

    <div class="max-w-6xl mx-auto px-6 py-16">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-12">
            <!-- Brand Column -->
            <div>
                <h3 class="text-xl font-black text-gray-900 mb-4 flex items-center gap-2">
                    Comiquería Aguilar
                </h3>
                <p class="text-gray-500 text-sm leading-relaxed mb-6">
                    Tu portal al multiverso. Cómics, mangas y novelas gráficas seleccionadas con pasión.
                </p>
                <div class="flex space-x-3">
                    <a href="https://www.facebook.com/profile.php?id=61590256484540" target="_blank" class="w-10 h-10 rounded-xl bg-gray-100 hover:bg-red-50 flex items-center justify-center text-gray-400 hover:text-red-600 transition-all hover:-translate-y-1" title="Facebook">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
                    </a>
                    <a href="https://www.instagram.com/comiqueria4?igsh=bjI1b2dwZ2NoaGNy" target="_blank" class="w-10 h-10 rounded-xl bg-gray-100 hover:bg-red-50 flex items-center justify-center text-gray-400 hover:text-red-600 transition-all hover:-translate-y-1" title="Instagram">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
                    </a>
                    <a href="https://www.tiktok.com/@comiqueriaguilar?is_from_webapp=1&sender_device=pc" target="_blank" class="w-10 h-10 rounded-xl bg-gray-100 hover:bg-red-50 flex items-center justify-center text-gray-400 hover:text-red-600 transition-all hover:-translate-y-1" title="TikTok">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"></path></svg>
                    </a>
                    <a href="https://www.youtube.com/@ComiqueriaAguilar" target="_blank" class="w-10 h-10 rounded-xl bg-gray-100 hover:bg-red-50 flex items-center justify-center text-gray-400 hover:text-red-600 transition-all hover:-translate-y-1" title="YouTube">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 0 0-1.95 1.96A29 29 0 0 0 1 11.54a29 29 0 0 0 .46 5.12 2.78 2.78 0 0 0 1.95 1.96C5.12 19.08 12 19.08 12 19.08s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.96A29 29 0 0 0 23 11.54a29 29 0 0 0-.46-5.12z"></path><polygon points="9.75 15.02 15.5 11.54 9.75 8.06 9.75 15.02"></polygon></svg>
                    </a>
                </div>
            </div>

            <!-- Quick Links -->
            <div>
                <h4 class="text-sm font-bold text-gray-400 uppercase tracking-wider mb-4">Explorar</h4>
                <ul class="space-y-3">
                    <li><a href="/" class="text-gray-600 hover:text-red-600 transition-colors text-sm font-medium flex items-center gap-2 group"><span class="w-1 h-1 rounded-full bg-gray-300 group-hover:bg-red-500 transition-colors"></span> Inicio</a></li>
                    <li><a href="/catalogo" class="text-gray-600 hover:text-red-600 transition-colors text-sm font-medium flex items-center gap-2 group"><span class="w-1 h-1 rounded-full bg-gray-300 group-hover:bg-red-500 transition-colors"></span> Catálogo</a></li>
                    <li><a href="/sobre-nosotros" class="text-gray-600 hover:text-red-600 transition-colors text-sm font-medium flex items-center gap-2 group"><span class="w-1 h-1 rounded-full bg-gray-300 group-hover:bg-red-500 transition-colors"></span> Sobre Nosotros</a></li>
                    <li><a href="/faq" class="text-gray-600 hover:text-red-600 transition-colors text-sm font-medium flex items-center gap-2 group"><span class="w-1 h-1 rounded-full bg-gray-300 group-hover:bg-red-500 transition-colors"></span> Preguntas Frecuentes</a></li>
                </ul>
            </div>

            <!-- Contact -->
            <div>
                <h4 class="text-sm font-bold text-gray-400 uppercase tracking-wider mb-4">Contacto</h4>
                <ul class="space-y-3">
                    <li class="flex items-center gap-3 text-sm text-gray-600">
                        <div class="w-8 h-8 rounded-lg bg-green-50 flex items-center justify-center text-green-600 shrink-0">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="none"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/></svg>
                        </div>
                        <a href="https://wa.me/59177124861" target="_blank" class="hover:text-green-600 transition-colors">+591 77124861</a>
                    </li>
                    <li class="flex items-center gap-3 text-sm text-gray-600">
                        <div class="w-8 h-8 rounded-lg bg-blue-50 flex items-center justify-center text-blue-600 shrink-0">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
                        </div>
                        <span>info@comiqueriaaguilar.com</span>
                    </li>
                    <li class="flex items-center gap-3 text-sm text-gray-600">
                        <div class="w-8 h-8 rounded-lg bg-red-50 flex items-center justify-center text-red-600 shrink-0">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
                        </div>
                        <span>Sucre, Bolivia</span>
                    </li>
                </ul>
            </div>
        </div>

        <!-- Bottom bar -->
        <div class="border-t border-gray-100 pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
            <p class="text-xs text-gray-400">
                &copy; 2026 Comiquería Aguilar. Todos los derechos reservados.
            </p>
            <p class="text-xs text-gray-400">
                Proyecto Universitario — E-Commerce Moderno Full-Stack
            </p>
        </div>
    </div>
</footer>
