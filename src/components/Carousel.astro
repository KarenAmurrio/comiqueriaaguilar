---
// src/components/Carousel.astro
---
<section class="pt-32 pb-12 px-6">
    <div class="max-w-6xl mx-auto relative rounded-3xl overflow-hidden shadow-2xl h-[400px] md:h-[500px] bg-gray-900 group" id="hero-carousel">
        <div class="carousel-slide absolute inset-0 transition-opacity duration-1000 opacity-100">
            <img src="/banner1.jpg" alt="Banner 1" class="w-full h-full object-cover opacity-60" />
            <div class="absolute inset-0 flex flex-col justify-center items-center text-center p-6">
                <span class="bg-red-600 text-white text-xs font-black px-3 py-1 rounded-full mb-4 tracking-widest">NUEVA COLECCIÓN</span>
                <h2 class="text-4xl md:text-6xl font-black text-white mb-4 drop-shadow-lg">El Multiverso de DC</h2>
                <p class="text-lg text-gray-200 max-w-xl drop-shadow-md">Descubre las novelas gráficas definitivas y ediciones absolute.</p>
            </div>
        </div>
        <div class="carousel-slide absolute inset-0 transition-opacity duration-1000 opacity-0 pointer-events-none">
            <img src="/banner2.jpg" alt="Banner 2" class="w-full h-full object-cover opacity-60" />
            <div class="absolute inset-0 flex flex-col justify-center items-center text-center p-6">
                <span class="bg-red-600 text-white text-xs font-black px-3 py-1 rounded-full mb-4 tracking-widest">ZONA MANGA</span>
                <h2 class="text-4xl md:text-6xl font-black text-white mb-4 drop-shadow-lg">Aventuras Épicas</h2>
                <p class="text-lg text-gray-200 max-w-xl drop-shadow-md">Completa tu colección con los tomos recién llegados de Japón.</p>
            </div>
        </div>

        <!-- Navigation Buttons -->
        <button id="prev-slide" class="absolute left-4 top-1/2 -translate-y-1/2 bg-black/40 hover:bg-black/60 text-white p-3 rounded-full backdrop-blur-sm opacity-0 group-hover:opacity-100 transition-all duration-300 z-20 hover:scale-110">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
        </button>
        <button id="next-slide" class="absolute right-4 top-1/2 -translate-y-1/2 bg-black/40 hover:bg-black/60 text-white p-3 rounded-full backdrop-blur-sm opacity-0 group-hover:opacity-100 transition-all duration-300 z-20 hover:scale-110">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
        </button>

        <div class="absolute bottom-6 left-0 right-0 flex justify-center space-x-3 z-20" id="carousel-dots">
            <button class="carousel-dot w-3 h-3 rounded-full bg-white transition-all hover:scale-125" data-index="0"></button>
            <button class="carousel-dot w-3 h-3 rounded-full bg-white/50 transition-all hover:bg-white/80 hover:scale-125" data-index="1"></button>
        </div>
    </div>
</section>